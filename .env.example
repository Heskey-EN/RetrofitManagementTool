# Supabase connection — copy this file to ".env" and fill in your project values.
# Find these in your Supabase dashboard: Project Settings -> API.
#
# Until these are set, the app runs in LOCAL mode: jobs are stored in your
# browser and synced across tabs on the same machine (no multi-user sync).
# Set both values to enable real-time sync across all 40-50 users.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
